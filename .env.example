# ──────────────────────────────────────────────
# Smart Canteen — Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# Flask
FLASK_ENV=development           # "development" or "production"

# Secrets — REQUIRED in production
SECRET_KEY=                     # e.g. openssl rand -hex 32
JWT_SECRET_KEY=                 # e.g. openssl rand -hex 32
JWT_ACCESS_HOURS=24             # token lifetime in hours

# Database
DATABASE_URL=                   # default: SQLite in backend/instance/canteen.db

# CORS
CORS_ORIGINS=*                  # comma-separated, e.g. https://myapp.com,https://admin.myapp.com
